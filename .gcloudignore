# .gcloudignore
# This file prevents large, unnecessary files from being uploaded to Cloud Build.

.gcloudignore
.git
.gitignore
node_modules/
**/node_modules/
.next/
dist/
build/
.env
.env.local
.env.*.local
*.log
.DS_Store
.agent/
.gemini/
.gemini_antigravity/

# Exclude large local backups and copies
*copy*
promethea-engine*
sbi_prototype*

# Build artifacts
*.tsbuildinfo
.incremental
**/dist/
**/build/
