# .gcloudignore - include only source packages needed for authentication-service
# Ignore everything by default
*
# Unignore essential root files
!package.json
!package-lock.json
!pnpm-workspace.yaml
!*.env
!tsconfig*.json
!ROADMAP.md
# Unignore all source packages (authentication-service and its dependencies)
!packages/**
# Exclude heavy directories within packages
packages/**/node_modules/
packages/**/dist/
packages/**/.next/
packages/**/.firebase/
packages/**/.gemini/
**/tsconfig.tsbuildinfo
# Exclude common large files
*.log
*.pdf
