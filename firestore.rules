/**
 * @fileOverview Firestore Security Rules for the Promethea Network State.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user-specific data while allowing public read access to certain collections.
 * Write access is carefully controlled to ensure data integrity and prevent unauthorized modifications. Data validation is relaxed to allow for rapid prototyping and schema iteration.
 *
 * Data Structure:
 * - Citizens are stored in `/citizens/{citizenId}`.
 * - Proposals are stored in `/proposals/{proposalId}`.
 * - Real-world assets are stored in `/real_world_assets/{assetId}`.
 * - Universal Value Tokens are stored in `/universal_value_tokens/{tokenId}`.
 * - Votes are stored in `/votes/{voteId}`.
 * - Tasks are stored in `/tasks/{taskId}`.
 * - DAC parameters are stored in `/dac_params/{dacParamsId}`.
 * - Constitutions are stored in `/constitutions/{constitutionId}`.
 *
 * Key Security Decisions:
 * - Citizens can only create their own Citizen document, and no one can modify or delete it.
 * - Public read access is enabled for all collections to facilitate data discovery and display.
 * - Write access to DAC parameters is denied to all clients.
 * - The 'canon' constitution document is publicly readable and writable.
 *
 * Denormalization for Authorization:
 * - For `/universal_value_tokens/{tokenId}`, the `ownerId` field is used to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows citizens to create their own profile. No one can update or delete citizen profiles.
     * @path /citizens/{citizenId}
     * @allow (create) User with UID 'citizenId' can create their own profile.
     * @deny (create) User with UID 'anotherUserId' cannot create a profile with ID 'citizenId'.
     * @deny (update) No one can update a citizen profile.
     * @deny (delete) No one can delete a citizen profile.
     * @principle Enforces self-creation for citizen profiles, preventing unauthorized profile creation and modification.
     */
    match /citizens/{citizenId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.auth.uid == citizenId;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read proposals, but only the proposer can create, update, or delete.
     * @path /proposals/{proposalId}
     * @allow (get, list) Any user can read any proposal.
     * @allow (create) User with UID 'proposerId' can create a proposal.
     * @deny (create) User with UID 'anotherUserId' cannot create a proposal with 'proposerId'.
     * @deny (update) User can not update any proposal.
     * @deny (delete) User can not delete any proposal.
     * @principle Allows public read access to proposals while restricting write access to the proposer.
     */
    match /proposals/{proposalId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read real-world assets, but no one can create, update, or delete them.
     * @path /real_world_assets/{assetId}
     * @allow (get, list) Any user can read any real-world asset.
     * @deny (create) No one can create a real-world asset.
     * @deny (update) No one can update a real-world asset.
     * @deny (delete) No one can delete a real-world asset.
     * @principle Allows public read access to real-world assets while preventing unauthorized modification.
     */
    match /real_world_assets/{assetId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read universal value tokens, but only the owner can create, update, or delete.
     * @path /universal_value_tokens/{tokenId}
     * @allow (get, list) Any user can read any universal value token.
     * @allow (create) User with UID 'ownerId' can create a universal value token.
     * @deny (create) User with UID 'anotherUserId' cannot create a universal value token with 'ownerId'.
     * @deny (update) User can not update any token.
     * @deny (delete) User can not delete any token.
     * @principle Allows public read access to universal value tokens while restricting write access to the owner.
     */
    match /universal_value_tokens/{tokenId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read votes, but no one can create, update, or delete them.
     * @path /votes/{voteId}
     * @allow (get, list) Any user can read any vote.
     * @deny (create) No one can create a vote.
     * @deny (update) No one can update a vote.
     * @deny (delete) No one can delete a vote.
     * @principle Allows public read access to votes while preventing unauthorized modification.
     */
    match /votes/{voteId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows anyone to read tasks, but no one can create, update, or delete them.
     * @path /tasks/{taskId}
     * @allow (get, list) Any user can read any task.
     * @deny (create) No one can create a task.
     * @deny (update) No one can update a task.
     * @deny (delete) No one can delete a task.
     * @principle Allows public read access to tasks while preventing unauthorized modification.
     */
    match /tasks/{taskId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Restricts access to DAC parameters. No one can read, create, update, or delete them.
     * @path /dac_params/{dacParamsId}
     * @deny (get, list) No one can read DAC parameters.
     * @deny (create) No one can create DAC parameters.
     * @deny (update) No one can update DAC parameters.
     * @deny (delete) No one can delete DAC parameters.
     * @principle Restricts all access to DAC parameters for security reasons.
     */
    match /dac_params/{dacParamsId} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read and write access to the constitution document with id 'canon'. Other constitution documents are not accessible.
     * @path /constitutions/{constitutionId}
     * @allow (get, list, create, update, delete) Any user can read and write the canon constitution.
     * @principle Allows public read/write access to the constitution.
     */
    match /constitutions/{constitutionId} {
        allow get: if true;
        allow list: if true;
        allow create: if constitutionId == 'canon';
        allow update: if constitutionId == 'canon';
        allow delete: if constitutionId == 'canon';
    }
  }

  // Helper function to determine if a user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }
}