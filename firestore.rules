
/**
 * @fileOverview Firestore Security Rules for the Promethea Network State.
 *
 * Core Philosophy:
 * This ruleset prioritizes ease of iteration and comprehensive platform-wide read access as per the request.
 * All documents are readable by any user, regardless of authentication status.
 * Write access to each document is strictly controlled based on ownership and relational integrity.
 *
 * Data Structure:
 * The Firestore database consists of top-level collections for core entities
 * such as `citizens`, `proposals`, `real_world_assets`, `universal_value_tokens`, `votes`,
 * `tasks`, `dac_params`, and `constitutions`.
 *
 * Key Security Decisions:
 * - Platform-wide read access is enabled to facilitate development and exploration, per the explicit request.
 * - Write operations are strictly limited to authorized users based on ownership or, for certain collections, relational integrity.
 * - Data validation is limited to checking ownership on document creation and enforcing immutability of key relational fields on updates.
 *
 * Denormalization for Authorization:
 * - In the current data model, `ownerId`, `proposerId`, and `assigneeId` fields are used in various documents to denote ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description GLOBAL SOVEREIGN READ ACCESS.
     * All public persistent data in the Promethean Substrate is openly auditable by any citizen.
     */
    match /{document=**} {
      allow read: if true;
    }

    /**
     * @description WRITE PROTECTION.
     * State mutations still require identity and authorization.
     */

    /**
     * @description Controls access to citizen profiles.
     * @path /citizens/{citizenId}
     * @allow create: A user can only create their own citizen document. The document ID must match their Firebase Auth UID.
     * @allow update: A user can only update their own document, and cannot change immutable fields like their ID or DID.
     * @allow delete: Deleting a citizen profile is forbidden to preserve historical integrity.
     * @principle Enforces strict ownership for creation and modification while allowing public reads.
     */
    match /citizens/{citizenId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == citizenId;
      allow update: if isSignedIn() && isOwner(citizenId);
      allow delete: if false;
    }

    /**
     * @description Grants read access to all users and restricts write access to the proposal creator.
     * @path /proposals/{proposalId}
     * @allow create: Only a signed-in user can create a proposal, and the proposerId must match their UID.
     * @allow update, delete: Only the proposal creator can update/delete the proposal, and only if the document already exists.
     * @deny create: if request.auth.uid != request.resource.data.proposerId; // A proposal's proposerId must match the user's UID on creation.
     * @deny update: if request.auth.uid != resource.data.proposerId; // A proposal's proposerId cannot be changed.
     * @deny delete: if request.auth.uid != resource.data.proposerId; // A proposal's proposerId cannot be changed.
     * @principle Enforces document ownership for writes and platform wide read access.
     */
    match /proposals/{proposalId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.proposerId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.proposerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.proposerId;
    }

    /**
     * @description Grants read access to all users and restricts write access.
     * @path /real_world_assets/{assetId}
     * @allow create: if false; // Assets are only created via passed proposals by a backend function.
     * @allow update: if false; // Future rule: allow asset owner to update.
     * @allow delete: if false; // Future rule: allow asset owner to delete.
     * @principle Write access is disabled for direct user interaction.
     */
    match /real_world_assets/{assetId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Grants read access to all users and restricts write access to the token owner.
     * @path /universal_value_tokens/{tokenId}
     */
    match /universal_value_tokens/{tokenId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isSignedIn() && isOwner(resource.data.ownerId);
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    /**
     * @description Grants read access to all users and restricts write access to the voter.
     * @path /votes/{voteId}
     */
    match /votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.citizenId;
      allow update: if isSignedIn() && isExistingVoter(resource.data.citizenId);
      allow delete: if isSignedIn() && isExistingVoter(resource.data.citizenId);
    }

    /**
     * @description Grants read access to all users and restricts write access to the assignee.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isExistingAssignee(resource.data.assigneeId);
      allow delete: if false;
    }

    /**
     * @description Controls access to pledges.
     * @path /pledges/{pledgeId}
     */
    match /pledges/{pledgeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.citizenId == request.auth.uid;
      allow update, delete: if false;
    }
    
    /**
     * @description Controls access to gap loans.
     * @path /gap_loans/{gapLoanId}
     */
    match /gap_loans/{gapLoanId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.proposerId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.proposerId || request.auth.uid == resource.data.funderId);
      allow delete: if false;
    }

    /**
     * @description Grants read access to all users and restricts write access to administrators.
     * @path /dac_params/{dacParamsId}
     */
    match /dac_params/{dacParamsId} {
      allow read: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Grants read access to all users and restricts write access.
     * @path /constitutions/{constitutionId}
     */
    match /constitutions/{constitutionId} {
        allow read: if true;
        allow create, update, delete: if false;
    }

    /**
     * @description Public transmissions from the Sovereign Intelligence.
     */
    match /narrative/{postId} {
        allow read: if true;
        allow create, update, delete: if false; // Managed by Intelligence engine
    }

    /**
     * @description The Network State Marketplace listings.
     */
    match /marketplace/{itemId} {
        allow read: if true;
        allow create, update, delete: if false;
    }

    /**
     * @description Ingestion staging for citizen proposals.
     */
    match /ingestions/{ingestionId} {
        allow read: if true;
        allow create: if true; // Allowed so citizens can stage proposals
        allow update, delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingProposer(proposerId) {
        return isSignedIn() && isOwner(proposerId) && exists(/databases/$(database)/documents/proposals/$(proposerId));
    }

    function isExistingVoter(citizenId) {
        return isSignedIn() && isOwner(citizenId) && exists(/databases/$(database)/documents/votes/$(citizenId));
    }

    function isExistingAssignee(assigneeId) {
        return isSignedIn() && isOwner(assigneeId) && exists(/databases/$(database)/documents/tasks/$(assigneeId));
    }
  }
}
