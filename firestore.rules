rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to citizen profiles.
     * @path /citizens/{citizenId}
     * @allow (create) Signed-in user creates their own citizen profile.
     * @allow (get, list, update, delete) Signed-in user accesses their own citizen profile.
     * @deny (create) Signed-in user attempts to create a citizen profile for another user.
     * @deny (update, delete) Signed-in user attempts to modify or delete another user's citizen profile.
     * @principle Enforces document ownership for reads and writes.
     */
    match /citizens/{citizenId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(citizenId) {
        return isSignedIn() && request.auth.uid == citizenId;
      }
      function isExistingOwner(citizenId) {
        return isSignedIn() && request.auth.uid == resource.data.id;
      }

      allow get: if isOwner(citizenId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isSignedIn() && request.auth.uid == citizenId;
      allow update: if isOwner(citizenId);
      allow delete: if isOwner(citizenId);
    }

    /**
     * @description Controls access to governance proposals.
     * @path /proposals/{proposalId}
     * @allow (create) Signed-in user creates a proposal with their ID as proposerId.
     * @allow (get, list) Public read access to proposals.
     * @allow (update, delete) Only the owner can update/delete.
     * @deny (create) Signed-in user attempts to create a proposal with a different proposerId.
     * @deny (update, delete) Signed-in user attempts to modify or delete another user's proposal.
     * @principle Enforces document ownership for writes.
     */
    match /proposals/{proposalId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(proposalId) {
        return isSignedIn() && request.auth.uid == resource.data.proposerId;
      }
      function isExistingOwner(proposalId) {
        return isSignedIn() && resource.data.proposerId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.proposerId == request.auth.uid;
      allow update: if isOwner(proposalId);
      allow delete: if isOwner(proposalId);
    }

    /**
     * @description Controls access to real-world asset data.
     * @path /real_world_assets/{assetId}
     * @allow (get, list) Public read access to assets.
     * @allow (create) Signed-in user can create an asset.
     * @allow (update, delete) Only the owner can update/delete.
     * @deny (update, delete) Signed-in user attempts to modify or delete another user's asset.
     * @principle Enforces document ownership for writes.
     */
    match /real_world_assets/{assetId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      // TODO: Need to clarify asset ownership.  Assuming a denormalized 'ownerId' field exists.
      function isOwner(assetId) {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }
      function isExistingOwner(assetId) {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn() && request.resource.data.ownerId == request.auth.uid; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to universal value tokens.
     * @path /universal_value_tokens/{tokenId}
     * @allow (get, list) Public read access to tokens.
     * @allow (create) Signed-in user can create a token with their ID as ownerId.
     * @allow (update, delete) Only the owner can update/delete.
     * @deny (create) Signed-in user attempts to create a token with a different ownerId.
     * @deny (update, delete) Signed-in user attempts to modify or delete another user's token.
     * @principle Enforces document ownership for writes.
     */
    match /universal_value_tokens/{tokenId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(tokenId) {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }
      function isExistingOwner(tokenId) {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(tokenId);
      allow delete: if isOwner(tokenId);
    }

    /**
     * @description Controls access to votes cast by citizens.
     * @path /votes/{voteId}
     * @allow (get, list) Public read access to votes.
     * @allow (create) Signed-in user can create a vote with their ID as citizenId.
     * @allow (update, delete) Only the owner can update/delete.
     * @deny (create) Signed-in user attempts to create a vote with a different citizenId.
     * @deny (update, delete) Signed-in user attempts to modify or delete another user's vote.
     * @principle Enforces document ownership for writes.
     */
    match /votes/{voteId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(voteId) {
        return isSignedIn() && request.auth.uid == resource.data.citizenId;
      }
      function isExistingOwner(voteId) {
        return isSignedIn() && resource.data.citizenId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.citizenId == request.auth.uid;
      allow update: if isOwner(voteId);
      allow delete: if isOwner(voteId);
    }

    /**
     * @description Controls access to tasks related to real-world asset management.
     * @path /tasks/{taskId}
     * @allow (get, list) Public read access to tasks.
     * @allow (create) Signed-in user can create a task.
     * @allow (update, delete) Only the assignee or owner can update/delete.
     * @deny (update, delete) Signed-in user attempts to modify or delete a task they are not assigned to or do not own.
     * @principle Enforces document ownership for writes.
     */
    match /tasks/{taskId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      // TODO: Need to clarify task ownership.  Assuming a denormalized 'ownerId' field exists.
      function isAssignee(taskId) {
        return isSignedIn() && request.auth.uid == resource.data.assigneeId;
      }
      function isOwner(taskId) {
        return isSignedIn() && request.auth.uid == resource.data.ownerId;
      }
      function isExistingOwner(taskId) {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.assigneeId == request.auth.uid); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || request.resource.data.assigneeId == request.auth.uid); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to DAC parameters.
     * @path /dac_params/{dacParamsId}
     * @allow (get, list) Public read access to DAC parameters.
     * @allow (create, update, delete) Restricted to administrators.
     * @deny (create, update, delete) Non-administrators cannot modify DAC parameters.
     * @principle Restricts writes to administrators.
     */
    match /dac_params/{dacParamsId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isAdmin() {
        // TODO: Implement proper admin check (e.g., custom claim).
        return false;
      }

      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Implement proper admin check (e.g., custom claim).
    }

    /**
     * @description Controls access to the living constitution.
     * @path /constitutions/{constitutionId}
     * @allow (get, list) Public read access to the constitution.
     * @allow (create, update, delete) Restricted to administrators.
     * @deny (create, update, delete) Non-administrators cannot modify the constitution.
     * @principle Restricts writes to administrators.
     */
    match /constitutions/{constitutionId} {
      // Helpers:
      function isSignedIn() {
        return request.auth != null;
      }
      function isAdmin() {
        // TODO: Implement proper admin check (e.g., custom claim).
        return false;
      }

      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Implement proper admin check (e.g., custom claim).
    }
  }
}