/**
 * @fileoverview Firestore Security Rules for the Promethea Network State.
 *
 * Core Philosophy:
 * This ruleset prioritizes public read access for most data while strictly controlling write access to authorized users.
 * Actions that require personal details or affect a user's state (e.g., voting, creating proposals) are protected by authentication checks.
 *
 * Data Structure:
 * The Firestore database consists of several top-level collections, including `citizens`, `proposals`, `real_world_assets`, `universal_value_tokens`, `votes`, `tasks`, `dac_params`, and `constitutions`.
 *
 * Key Security Decisions:
 * - Most collections are publicly readable (`get`, `list`).
 * - Write operations (`create`, `update`, `delete`) require authentication and are often restricted to the owner of the data.
 * - The rules DO NOT validate the full data schema during writes to allow for rapid prototyping. Only authorization-critical fields are validated.
 * - `dac_params` are write-protected to prevent unauthorized modification of DAC parameters.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to citizen data and restricts write access to the owner.
     * @path /citizens/{citizenId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): Only the citizen with matching ID.
     * @deny (create, update, delete): If the user is not authenticated or the ID does not match.
     * @principle Enforces document ownership for writes; public read access.
     */
    match /citizens/{citizenId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(citizenId) {
        return isSignedIn() && request.auth.uid == citizenId;
      }

      function isExistingOwner(citizenId) {
          return isOwner(citizenId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(citizenId) && request.resource.data.id == citizenId;
      allow update: if isExistingOwner(citizenId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(citizenId);
    }

    /**
     * @description Grants public read access to proposals and restricts write access to the proposer.
     * @path /proposals/{proposalId}
     * @allow (get, list): Public access.
     * @allow (create): Only authenticated users.
     * @allow (update, delete): Only the proposer of the proposal.
     * @deny (create): If the user is not authenticated.
     * @deny (update, delete): If the user is not the proposer or the proposal does not exist.
     * @principle Enforces document ownership for writes; public read access.
     */
    match /proposals/{proposalId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isProposer(proposerId) {
        return isSignedIn() && request.auth.uid == proposerId;
      }

        function isExistingProposer(proposerId) {
            return isProposer(proposerId) && resource != null;
        }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isExistingProposer(resource.data.proposerId);
      allow delete: if isExistingProposer(resource.data.proposerId);
    }

    /**
     * @description Grants public read access to real-world asset data and restricts write access.
     * @path /real_world_assets/{assetId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @principle Public read access; write access requires further definition based on an ownership field.
     */
    match /real_world_assets/{assetId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Grants public read access to universal value tokens and restricts write access to the owner.
     * @path /universal_value_tokens/{tokenId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): Only the owner of the token.
     * @deny (create, update, delete): If the user is not authenticated or the token does not exist.
     * @principle Enforces document ownership for writes; public read access.
     */
    match /universal_value_tokens/{tokenId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId;
      }

        function isExistingOwner(ownerId) {
            return isOwner(ownerId) && resource != null;
        }

      allow get, list: if true;
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isExistingOwner(resource.data.ownerId) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isExistingOwner(resource.data.ownerId);
    }

    /**
     * @description Grants public read access to votes and restricts write access to authenticated users.
     * @path /votes/{voteId}
     * @allow (get, list): Public access.
     * @allow (create): Only authenticated users.
     * @allow (update, delete): if false;
     * @deny (create): If the user is not authenticated.
     * @principle Public read access; authenticated users can create votes.
     */
    match /votes/{voteId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Grants public read access to tasks and restricts write access based on assignee or asset ownership.
     * @path /tasks/{taskId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): if false; // TODO: Add owner validation once the schema is updated with an ownership field.
     * @principle Public read access; write access requires further definition based on an ownership field.
     */
    match /tasks/{taskId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Restricts read and write access to DAC parameters.
     * @path /dac_params/{dacParamsId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): if false; //No one is allowed to modify dac_params, this would break the system
     * @principle Restricts write access to DAC parameters.
     */
    match /dac_params/{dacParamsId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Grants public read access to the constitution.
     * @path /constitutions/{constitutionId}
     * @allow (get, list): Public access.
     * @allow (create, update, delete): if false; // TODO: Define authorized editors (e.g., via a service account).
     * @principle Public read access to the constitution; write access requires further definition.
     */
    match /constitutions/{constitutionId} {
        allow get, list: if true;
        allow create, update, delete: if false; // TODO: Define authorized editors (e.g., via a service account).
    }
  }
}