/**
 * @fileOverview Firestore Security Rules for the Promethea Network State.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure, owner-only access to user-specific data, combined with public read access where appropriate.
 * Authorization decisions are made based on the `request.auth.uid` and denormalized data within the documents to minimize `get()` calls.
 *
 * Data Structure:
 * - /citizens/{citizenId}: Stores citizen profiles.  Citizen can create their own document.
 * - /proposals/{proposalId}: Stores governance proposals. Owner-only writes.
 * - /real_world_assets/{assetId}: Stores real-world assets. Owner-only writes.
 * - /universal_value_tokens/{tokenId}: Stores UVTs. Owner-only writes.
 * - /votes/{voteId}: Stores votes. Owner-only writes.
 * - /tasks/{taskId}: Stores tasks. Owner-only writes.
 * - /dac_params/{dacParamsId}: Stores DAC parameters. Owner-only writes.
 * - /constitutions/{constitutionId}: Stores the constitution documents. Public read, owner-only writes.
 *
 * Key Security Decisions:
 * - Public listing is enabled for the `constitutions` collection.
 * - All other collections require authentication for writes.
 * - Data validation is limited to ownership checks and relational integrity (e.g., `ownerId` consistency).
 *
 * Denormalization for Authorization:
 * - The `ownerId` or `authorId` field within documents is used for authorization checks, avoiding the need for additional reads.
 *
 * Structural Segregation:
 * - No explicit structural segregation is used. Drafts and published content are managed within the same collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows citizens to manage their own profiles.
     * @path /citizens/{citizenId}
     * @allow (create) User with UID 'citizenId' can create their own profile.
     * @deny (create) User with UID 'otherId' cannot create a profile for 'citizenId'.
     * @allow (get, list) Users can read citizen profiles.
     * @allow (update, delete) User with UID 'citizenId' can update/delete their own profile.
     * @deny (update, delete) User with UID 'otherId' cannot update/delete the profile for 'citizenId'.
     * @principle Enforces document ownership for writes; allows public reads.
     */
    match /citizens/{citizenId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == citizenId && request.resource.data.id == citizenId;
      allow update: if isSignedIn() && isExistingOwner(citizenId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(citizenId);
    }

    /**
     * @description Manages governance proposals.
     * @path /proposals/{proposalId}
     * @allow (create) User can create a proposal if the proposerId matches their UID.
     * @deny (create) User cannot create a proposal if the proposerId does not match their UID.
     * @allow (get, list) Users can read proposals.
     * @allow (update, delete) Only the owner can update/delete a proposal.
     * @deny (update, delete) Other users cannot update/delete a proposal.
     * @principle Enforces document ownership for writes.
     */
    match /proposals/{proposalId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.proposerId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwnerByField(resource.data.proposerId);
      allow delete: if isSignedIn() && isExistingOwnerByField(resource.data.proposerId);
    }

    /**
     * @description Manages real-world assets.
     * @path /real_world_assets/{assetId}
     * @allow (create) User can create an asset.
     * @deny (create) User cannot create an asset with invalid data.
     * @allow (get, list) Users can read asset information.
     * @allow (update, delete) Only the owner can update/delete an asset.
     * @deny (update, delete) Other users cannot update/delete an asset.
     * @principle Enforces document ownership for writes.
     */
    match /real_world_assets/{assetId} {
      allow get, list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages universal value tokens.
     * @path /universal_value_tokens/{tokenId}
     * @allow (create) User can create a UVT if the ownerId matches their UID.
     * @deny (create) User cannot create a UVT if the ownerId does not match their UID.
     * @allow (get, list) Users can read UVT information.
     * @allow (update, delete) Only the owner can update/delete a UVT.
     * @deny (update, delete) Other users cannot update/delete a UVT.
     * @principle Enforces document ownership for writes.
     */
    match /universal_value_tokens/{tokenId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwnerByField(resource.data.ownerId);
      allow delete: if isSignedIn() && isExistingOwnerByField(resource.data.ownerId);
    }

    /**
     * @description Stores votes cast by citizens.
     * @path /votes/{voteId}
     * @allow (create) User can create a vote if the citizenId matches their UID.
     * @deny (create) User cannot create a vote if the citizenId does not match their UID.
     * @allow (get, list) Users can read votes.
     * @allow (update, delete) Only the owner can update/delete a vote.
     * @deny (update, delete) Other users cannot update/delete a vote.
     * @principle Enforces document ownership for writes.
     */
    match /votes/{voteId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.citizenId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwnerByField(resource.data.citizenId);
      allow delete: if isSignedIn() && isExistingOwnerByField(resource.data.citizenId);
    }

    /**
     * @description Manages tasks related to real-world asset management.
     * @path /tasks/{taskId}
     * @allow (create) User can create a task.
     * @deny (create) User cannot create a task with invalid data.
     * @allow (get, list) Users can read task information.
     * @allow (update, delete) Only the owner (assignee) can update/delete a task.
     * @deny (update, delete) Other users cannot update/delete a task.
     * @principle Enforces document ownership for writes.
     */
    match /tasks/{taskId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.assigneeId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwnerByField(resource.data.assigneeId);
      allow delete: if isSignedIn() && isExistingOwnerByField(resource.data.assigneeId);
    }

    /**
     * @description Manages DAC parameters.
     * @path /dac_params/{dacParamsId}
     * @allow (create) User can create a DAC parameter.
     * @deny (create) User cannot create a DAC parameter with invalid data.
     * @allow (get, list) Users can read DAC parameters.
     * @allow (update, delete) Only the owner can update/delete a DAC parameter.
     * @deny (update, delete) Other users cannot update/delete a DAC parameter.
     */
    match /dac_params/{dacParamsId} {
      allow get, list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages constitution versions.
     * @path /constitutions/{constitutionId}
     * @allow (create) User can create a constitution version.
     * @deny (create) User cannot create a constitution version with invalid data.
     * @allow (get, list) Users can read constitution versions.
     * @allow (update, delete) Only the owner can update/delete a constitution version.
     * @deny (update, delete) Other users cannot update/delete a constitution version.
     */
    match /constitutions/{constitutionId} {
      allow get, list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isExistingOwnerByField(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId && resource != null;
    }
  }
}