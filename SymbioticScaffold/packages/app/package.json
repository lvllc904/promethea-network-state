    "@promethea/lib": "5.2.3",
    "@promethea/ui": "5.2.3",
    "@promethea/pubsub": "5.2.3",
    "@promethea/guardian": "5.2.3",
    "ethers": "^6.13.1",
    "framer-motion": "^11.2.14",
    "next": "14.2.33",
    "qrcode.react": "3.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
