{
  "name": "promethea-antigravity-bundle",
  "private": true,
  "version": "5.2.3",
  "scripts": {
    "build:lib": "npm run build --workspace=@promethea/lib",
    "build:guardian": "npm run build --workspace=@promethea/guardian",
    "build:auth": "npm run build --workspace=@promethea/authentication-service",
    "build": "npm run build:lib && npm run build:guardian && npm run build:auth",
    "penny:test": "npm run build:lib && node scripts/runPennyTest.js"
  },
  "workspaces": [
    "packages/*",
    "packages/services/*"
  ],
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "dotenv": "^16.5.0",
    "firebase-admin": "^13.6.0",
    "firebase-frameworks": "^0.11.8",
    "sharp": "0.33.5",
    "typescript": "5.5.4",
    "tailwindcss": "^3.4.19"
  }
}