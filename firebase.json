{
    "hosting": {
        "source": "packages/app",
        "framework": "nextjs",
        "target": "app",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/api/ai/**",
                "run": {
                    "serviceId": "ai-service",
                    "region": "us-central1"
                }
            },
            {
                "source": "/api/engine/**",
                "run": {
                    "serviceId": "economic-engine",
                    "region": "us-central1"
                }
            }
        ]
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    }
}