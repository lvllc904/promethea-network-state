    "@promethea/ui": "workspace:*",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "firebase": "^9.23.0",
    "framer-motion": "^11.2.14",
    "lucide-react": "^0.395.0",
    "next": "14.2.33",
